rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isDocHabitOwner() {
      return isAuthenticated() && request.auth.uid == get(/databases/$(database)/documents/habits/$(resource.data.habitId)).data.userId;
    }

    // User Profile
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Habits
    match /habits/{habitId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isDocOwner();
    }
    
    // Habit Logs
    match /habitLogs/{logId} {
      allow read: if isAuthenticated() && (
        exists(/databases/$(database)/documents/habits/$(resource.data.habitId)) && 
        get(/databases/$(database)/documents/habits/$(resource.data.habitId)).data.userId == request.auth.uid
      );
      allow create: if isAuthenticated() && (
        exists(/databases/$(database)/documents/habits/$(request.resource.data.habitId)) && 
        get(/databases/$(database)/documents/habits/$(request.resource.data.habitId)).data.userId == request.auth.uid
      );
      allow update, delete: if isAuthenticated() && (
        exists(/databases/$(database)/documents/habits/$(resource.data.habitId)) && 
        get(/databases/$(database)/documents/habits/$(resource.data.habitId)).data.userId == request.auth.uid
      );
    }
    
    // Meals
    match /meals/{mealId} {
      allow read, write: if isDocOwner() || (request.resource.data.userId == request.auth.uid);
    }
    
    // Workout Sessions
    match /workoutSessions/{sessionId} {
      allow read, write: if isDocOwner() || (request.resource.data.userId == request.auth.uid);
    }
    
    // Exercises
    match /exercises/{exerciseId} {
      allow read: if isAuthenticated() && (
        exists(/databases/$(database)/documents/workoutSessions/$(resource.data.sessionId)) && 
        get(/databases/$(database)/documents/workoutSessions/$(resource.data.sessionId)).data.userId == request.auth.uid
      );
      allow create: if isAuthenticated() && (
        exists(/databases/$(database)/documents/workoutSessions/$(request.resource.data.sessionId)) && 
        get(/databases/$(database)/documents/workoutSessions/$(request.resource.data.sessionId)).data.userId == request.auth.uid
      );
      allow update, delete: if isAuthenticated() && (
        exists(/databases/$(database)/documents/workoutSessions/$(resource.data.sessionId)) && 
        get(/databases/$(database)/documents/workoutSessions/$(resource.data.sessionId)).data.userId == request.auth.uid
      );
    }
    
    // Transactions
    match /transactions/{transactionId} {
      allow read, write: if isDocOwner() || (request.resource.data.userId == request.auth.uid);
    }
    
    // Goals
    match /goals/{goalId} {
      allow read, write: if isDocOwner() || (request.resource.data.userId == request.auth.uid);
    }
    
    // Journal Entries
    match /journalEntries/{entryId} {
      allow read, write: if isDocOwner() || (request.resource.data.userId == request.auth.uid);
    }
    
    // Brian Tracy Logs
    match /brianTracyLogs/{logId} {
      allow read, write: if isDocOwner() || (request.resource.data.userId == request.auth.uid);
    }
    
    // Schedule Events
    match /scheduleEvents/{eventId} {
      allow read, write: if isDocOwner() || (request.resource.data.userId == request.auth.uid);
    }
  }
}
